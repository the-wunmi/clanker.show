# AI (direct Anthropic API by default)
ANTHROPIC_API_KEY=
# AI_MODEL=claude-sonnet-4-20250514

# AI via AWS Bedrock (bearer token OR standard AWS creds)
# AWS_BEARER_TOKEN_BEDROCK=
# AWS_BEDROCK=true
# AWS_REGION=us-east-1

# Services
ELEVENLABS_API_KEY=
FIRECRAWL_API_KEY=

# Icecast
ICECAST_HOST=localhost
ICECAST_PORT=8000
ICECAST_SOURCE_PASSWORD=hackme
ICECAST_ADMIN_PASSWORD=admin

# App
PORT=3001
WEB_PORT=3000
ARCHIVE_PATH=./data/archive

# Database (SQLite by default, set postgresql:// URL for Postgres)
DATABASE_URL=file:./data/clanker.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/clanker

# Optional
DEFAULT_IDLE_BEHAVIOR=pause
AVERAGE_PROGRAM_MINUTES=30
LOG_LEVEL=info
