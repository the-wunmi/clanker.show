{
  "name": "station",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "db:generate": "bun run scripts/prisma-generate.ts generate",
    "db:migrate": "bun run scripts/prisma-generate.ts migrate deploy",
    "db:migrate:dev": "bun run scripts/prisma-generate.ts migrate dev",
    "db:studio": "bun run scripts/prisma-generate.ts studio",
    "postinstall": "bun run scripts/prisma-generate.ts generate"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.26.4",
    "@anthropic-ai/sdk": "^0.80.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.2.0",
    "@mendable/firecrawl-js": "^4.17.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "date-fns": "^4.1.0",
    "elevenlabs": "^1.59.0",
    "fastify": "^5.8.4",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma-adapter-bun-sqlite": "^0.7.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "bun-types": "^1.3.11",
    "prisma": "^7.5.0",
    "typescript": "^6.0.2"
  }
}
